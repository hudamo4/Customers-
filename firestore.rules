rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if the user is an admin
    function isAdmin() {
      return request.auth != null && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Helper function to check if the user is the owner of the document
    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    match /users/{userId} {
      allow read, write: if isOwner(userId) || isAdmin();
      // Allow query (list) for login lookup
      allow list: if request.auth != null;
    }

    match /shipments/{shipmentId} {
      allow read, write: if isAdmin() || (request.auth != null && (resource.data.userId == request.auth.uid || request.resource.data.userId == request.auth.uid));
      // Also allow creating/listing for authenticated users
      allow create, list: if request.auth != null;
    }

    match /invoices/{invoiceId} {
      allow read, write: if isAdmin() || (request.auth != null && (resource.data.userId == request.auth.uid || request.resource.data.userId == request.auth.uid));
      allow create, list: if request.auth != null;
    }

    match /notifications/{notificationId} {
      allow read, write: if isAdmin() || (request.auth != null && (resource.data.userId == request.auth.uid || request.resource.data.userId == request.auth.uid));
      allow create, list: if request.auth != null;
    }

    match /settings/{document} {
      // App customizations/settings are readable by everyone
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
